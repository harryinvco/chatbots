# Copy to .env and fill in. NEVER commit .env.
# Get a key at https://platform.openai.com/api-keys

# Used by the chat backend (api/chat.js) and the knowledge-base builder (scripts/build-kb.mjs)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Model configuration (optional; sensible defaults below) ---
# Chat model used to answer questions
CHAT_MODEL=gpt-4o
# Embedding model used for retrieval (must match what build:kb used)
EMBEDDING_MODEL=text-embedding-3-small
# Embedding dimensions (keep build:kb and runtime identical)
EMBEDDING_DIMENSIONS=512

# --- Crawl options (optional; only used by scripts/crawl.mjs) ---
# If ICPAC allowlists a header in a Cloudflare WAF skip rule, set it here so the
# crawler is never challenged (most reliable for an authorized crawl):
# BYPASS_HEADER=X-ICPAC-Crawl: your-shared-secret
# Or route the crawl through a residential proxy if this IP keeps getting challenged:
# PROXY_SERVER=http://host:port
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass

# --- Provider switch (optional) ---
# "openai" (default). Set to "anthropic" later to swap to Claude (requires ANTHROPIC_API_KEY).
LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_CHAT_MODEL=claude-opus-4-8
