# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key (https://console.anthropic.com/) — powers the replies.
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl API key (https://firecrawl.dev) — crawls + scrapes the ICPAC website.
FIRECRAWL_API_KEY=fc-...

# Chat history + scraped-page storage (Upstash Redis, a.k.a. Vercel KV).
# REQUIRED — the crawl, retrieval and chat history all use it.
# On Vercel: add the Upstash (KV) integration and these two are set for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password for the /admin history page (also used to trigger /api/refresh).
ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Optional tuning (sensible defaults shown)
# ---------------------------------------------------------------------------

# --- Model / generation ---
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=8000
# ANTHROPIC_EFFORT=medium        # low | medium | high | max
# ANTHROPIC_THINKING=adaptive    # adaptive | off  (off = faster, less synthesis)
# HISTORY_LIMIT=20               # messages of prior context sent to the model

# --- Web-search fallback ---
# When the scraped knowledge base can't answer, Claude searches the web to fill
# the gap (built-in web_search tool; billed by Anthropic per search).
# WEB_SEARCH=on                  # off to disable
# WEB_SEARCH_MAX_USES=4          # max searches Claude may run per question
# WEB_SEARCH_ALLOWED_DOMAINS=    # comma-separated allowlist (e.g. icpac.org.cy) — empty = whole web

# --- Crawl (Firecrawl) ---
# We discover URLs ourselves (sitemap + Firecrawl /map + known sections + recent
# year listings) and batch-scrape them with Firecrawl, which renders JS, gets
# past anti-bot, and returns clean markdown — including PDF text. Content on this
# site is largely in linked PDFs, so PDFs are scraped as first-class pages.
# FIRECRAWL_CRAWL_URL=https://www.icpac.org.cy/selk/en/   # site base (English section)
# FIRECRAWL_LIMIT=300            # total pages scraped per refresh (= Firecrawl credits)
# FIRECRAWL_ARTICLE_LIMIT=150    # cap on article-wrapper pages (leaves budget for their PDFs)
# FIRECRAWL_MAX_ROUNDS=4         # harvest passes (sections -> articles/PDFs -> article PDFs)
# FIRECRAWL_SITEMAP_URLS=        # override sitemap URLs (defaults try /selk/en/, /selk/, root)
# FIRECRAWL_NEWS_URLS=           # override news/events listing URLs
# FIRECRAWL_SECTION_URLS=        # override the section safety-net list
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v1   # pin a different API version if needed
# FIRECRAWL_TIMEOUT_MS=30000     # per-request timeout when talking to Firecrawl
# KB_STORE_CHARS=12000           # markdown chars stored per page
# CRAWL_MAX_ERRORS=8             # give up a crawl after this many consecutive poll errors
#
# Recent articles: the news listings hide article links behind ASP.NET post-backs,
# so we ID-back-fill — probe newDetails.aspx?id=N downward from the newest id.
# FIRECRAWL_ID_BACKFILL=on       # set to off to disable id probing
# FIRECRAWL_MAX_ID=2900          # anchor id for the back-fill; set to the newest news
#                                # id (open a recent item, copy id= from the URL)

# --- Retrieval (which pages get sent to Claude per question) ---
# RETRIEVE_LIMIT=15              # top relevant pages per question
# RETRIEVE_LATEST=5             # newest pages always included (for "latest news" questions)
# SEND_CHAR_CAP=6000            # chars per page sent to the model
# KB_EXCERPT_CHARS=800          # chars per page kept in the lightweight search index
# RECENCY_WEIGHT=2              # how much to favour newer pages in ranking

# --- Optional: only needed if you later add a scheduled refresh (cron) ---
# CRON_SECRET=
