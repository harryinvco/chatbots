# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key (https://console.anthropic.com/) — powers the replies.
ANTHROPIC_API_KEY=sk-ant-...

# ScraperAPI key (https://www.scraperapi.com/) — fetches the ICPAC website.
SCRAPERAPI_KEY=

# ---------------------------------------------------------------------------
# Chat history / cache storage (Upstash Redis, a.k.a. Vercel KV)
# Required to persist chat history for the admin page and to cache the scrape.
# On Vercel: add the Upstash (KV) integration and these two are set for you.
# ---------------------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Admin history page (/admin)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=change-me

# Secret Vercel sends with scheduled cron requests so /api/refresh is protected.
# Set this to any random string; Vercel forwards it automatically to cron jobs.
CRON_SECRET=

# ---------------------------------------------------------------------------
# Optional tuning (sensible defaults shown)
# ---------------------------------------------------------------------------

# Model + generation
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=8000
# ANTHROPIC_EFFORT=medium        # low | medium | high | max
# ANTHROPIC_THINKING=adaptive    # adaptive | off  (off = faster, less synthesis)
# HISTORY_LIMIT=20               # messages of prior context sent to the model

# Scraping
# SCRAPE_SEED_URLS=https://www.icpac.org.cy/selk/en/default.aspx
# SCRAPE_MAX_PAGES=8             # homepage + this many news/article pages
# SCRAPE_MAX_CHARS=9000          # text kept per page
# KB_TTL_SECONDS=21600           # how long a scrape stays "fresh" (6h)
# SCRAPE_PREMIUM=true            # ScraperAPI premium proxy (site is Cloudflare-protected)
# SCRAPE_RENDER=false            # set true if pages need JS rendering
# SCRAPE_ULTRA_PREMIUM=false     # last resort for tough anti-bot protection
# SCRAPE_COUNTRY=                # e.g. eu, cy
# SCRAPE_CONCURRENCY=4
# SCRAPE_TIMEOUT_MS=35000
