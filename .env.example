# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key (https://console.anthropic.com/) — powers the replies.
ANTHROPIC_API_KEY=sk-ant-...

# ScraperAPI key (https://www.scraperapi.com/) — fetches the ICPAC website.
SCRAPERAPI_KEY=

# Chat history + scraped-page storage (Upstash Redis, a.k.a. Vercel KV).
# REQUIRED — the crawl, retrieval and chat history all use it.
# On Vercel: add the Upstash (KV) integration and these two are set for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password for the /admin history page (also used to trigger /api/refresh).
ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Optional tuning (sensible defaults shown)
# ---------------------------------------------------------------------------

# --- Model / generation ---
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=8000
# ANTHROPIC_EFFORT=medium        # low | medium | high | max
# ANTHROPIC_THINKING=adaptive    # adaptive | off  (off = faster, less synthesis)
# HISTORY_LIMIT=20               # messages of prior context sent to the model

# --- Crawl (how the ~200 latest pages are discovered + scraped) ---
# The site pages its news/events archive with JS post-backs (invisible to a link
# crawler), so the crawler GENERATES the year-filtered listing URLs
# (news.aspx?...&year=YYYY, which work as plain GETs), fetches them in batches,
# and harvests the article links. Articles are ranked by id (higher = newer);
# static info pages come from the sitemap. The stale sitemap lastmod is ignored.
# SCRAPE_MAX_PAGES=200           # how many of the latest pages to keep
# SCRAPE_YEARS_BACK=12           # years of archive to generate per category (raise to go deeper)
# SCRAPE_BATCH=10                # pages scraped per /api/refresh call (keep low so each call stays under the timeout)
# SCRAPE_EXPAND_PER_BATCH=6      # year-listing pages fetched per /api/refresh call during discovery
# SCRAPE_CONCURRENCY=5           # parallel ScraperAPI requests (match your ScraperAPI plan)
# SCRAPE_SEED_URLS=https://www.icpac.org.cy/selk/default.aspx
# SCRAPE_NEWS_URLS=https://www.icpac.org.cy/selk/news.aspx?catid=1001,https://www.icpac.org.cy/selk/events.aspx?catid=1002,https://www.icpac.org.cy/selk/events.aspx?catid=1003
# SCRAPE_STATIC_RESERVE=40       # slots kept for static/info pages so news doesn't crowd them out
# SCRAPE_SITEMAP_URLS=          # comma-separated sitemap URLs; if empty, sitemap.xml is auto-discovered from the seed origin
# SCRAPE_MAX_CHARS=9000          # text stored per page
# SCRAPE_TIMEOUT_MS=35000        # per-request ScraperAPI timeout

# ScraperAPI proxy mode (the site is Cloudflare-protected, so premium is on by default)
# SCRAPE_PREMIUM=true
# SCRAPE_RENDER=false            # set true if pages need JS rendering
# SCRAPE_ULTRA_PREMIUM=false     # last resort for tough anti-bot protection
# SCRAPE_COUNTRY=                # e.g. eu, cy

# --- Retrieval (which pages get sent to Claude per question) ---
# RETRIEVE_LIMIT=15              # top relevant pages per question
# RETRIEVE_LATEST=5             # newest pages always included (for "latest news" questions)
# SEND_CHAR_CAP=6000            # chars per page sent to the model
# KB_EXCERPT_CHARS=800          # chars per page kept in the lightweight search index
# RECENCY_WEIGHT=2              # how much to favour newer pages in ranking

# --- Optional: only needed if you later add a scheduled refresh (cron) ---
# CRON_SECRET=
