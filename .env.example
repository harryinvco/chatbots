# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key (https://console.anthropic.com/) — powers the replies.
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl API key (https://firecrawl.dev) — crawls + scrapes the ICPAC website.
FIRECRAWL_API_KEY=fc-...

# Chat history + scraped-page storage (Upstash Redis, a.k.a. Vercel KV).
# REQUIRED — the crawl, retrieval and chat history all use it.
# On Vercel: add the Upstash (KV) integration and these two are set for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password for the /admin history page (also used to trigger /api/refresh).
ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Optional tuning (sensible defaults shown)
# ---------------------------------------------------------------------------

# --- Model / generation ---
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=8000
# ANTHROPIC_EFFORT=medium        # low | medium | high | max
# ANTHROPIC_THINKING=adaptive    # adaptive | off  (off = faster, less synthesis)
# HISTORY_LIMIT=20               # messages of prior context sent to the model

# --- Crawl (Firecrawl) ---
# Firecrawl crawls the site server-side (renders JS, gets past anti-bot,
# discovers URLs via sitemap + link following) and returns clean markdown.
# FIRECRAWL_CRAWL_URL=https://www.icpac.org.cy/selk/   # where the crawl starts
# FIRECRAWL_LIMIT=300            # max pages to crawl (= Firecrawl credits per refresh)
# FIRECRAWL_MAX_DEPTH=5          # how deep to follow links from the start URL
# FIRECRAWL_INCLUDE_PATHS=       # comma-separated regex path filters (empty = all under the start URL)
# FIRECRAWL_EXCLUDE_PATHS=[Ss]ecure/,[Uu]ser[Ll]ogin,[Ee]rror[Pp]age,aspxerrorpath,[Ss]itemap\.aspx,\.pdf$
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v1   # pin a different API version if needed
# FIRECRAWL_TIMEOUT_MS=30000     # per-request timeout when talking to Firecrawl
# KB_STORE_CHARS=12000           # markdown chars stored per page
# CRAWL_MAX_ERRORS=8             # give up a crawl after this many consecutive poll errors
# Round 2 (recent articles): after round 1 we harvest newdetails/eventdetails
# links from the scraped pages and scrape the newest of them. ID back-fill also
# probes newdetails.aspx?id=N downward from the newest id found, to reach recent
# articles the JS-paginated listings hide.
# FIRECRAWL_ID_BACKFILL=on       # set to off to disable id probing
# FIRECRAWL_MAX_ID=              # manual anchor id if auto-detection finds none
#                                # (open a recent news item and copy id= from the URL)

# --- Retrieval (which pages get sent to Claude per question) ---
# RETRIEVE_LIMIT=15              # top relevant pages per question
# RETRIEVE_LATEST=5             # newest pages always included (for "latest news" questions)
# SEND_CHAR_CAP=6000            # chars per page sent to the model
# KB_EXCERPT_CHARS=800          # chars per page kept in the lightweight search index
# RECENCY_WEIGHT=2              # how much to favour newer pages in ranking

# --- Optional: only needed if you later add a scheduled refresh (cron) ---
# CRON_SECRET=
